{
  "name": "gemma4-agent",
  "version": "0.1.0",
  "description": "A portable coding agent powered by Gemma 4",
  "type": "module",
  "main": "dist/launcher.js",
  "bin": {
    "gemma4-agent": "dist/launcher.js"
  },
  "files": [
    "dist",
    "opencode.json",
    "bootstrap.sh",
    "README.md"
  ],
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/launcher.js",
    "dev": "npx tsx src/launcher.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm publish",
    "pkg:all": "npm run pkg:win && npm run pkg:mac && npm run pkg:linux",
    "pkg:win": "pkg dist/launcher.js -t node20-win-x64 -o release/gemma4-agent-win-x64.exe",
    "pkg:mac-arm": "pkg dist/launcher.js -t node20-macos-arm64 -o release/gemma4-agent-macos-arm64",
    "pkg:mac-x64": "pkg dist/launcher.js -t node20-macos-x64 -o release/gemma4-agent-macos-x64",
    "pkg:mac": "npm run pkg:mac-arm",
    "pkg:linux": "pkg dist/launcher.js -t node20-linux-x64 -o release/gemma4-agent-linux-x64"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/user/gemma4-agent.git"
  },
  "keywords": [
    "gemma",
    "gemma4",
    "coding-agent",
    "ai",
    "llm",
    "llama.cpp",
    "opencode",
    "cli"
  ],
  "author": "",
  "homepage": "https://github.com/user/gemma4-agent#readme",
  "bugs": {
    "url": "https://github.com/user/gemma4-agent/issues"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "pkg": "^5.8.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0"
}
