{
  "name": "gemma4-agent",
  "version": "0.1.0",
  "description": "A portable coding agent powered by Gemma 4",
  "type": "module",
  "main": "dist/launcher.js",
  "bin": {
    "gemma4-agent": "dist/launcher.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/launcher.js",
    "dev": "tsx src/launcher.ts",
    "pkg:win": "pkg dist/launcher.js -t node20-win-x64 -o dist/gemma4-agent-win.exe",
    "pkg:mac": "pkg dist/launcher.js -t node20-macos-arm64 -o dist/gemma4-agent-mac",
    "pkg:linux": "pkg dist/launcher.js -t node20-linux-x64 -o dist/gemma4-agent-linux"
  },
  "dependencies": {
    "@huggingface/hub": "^2.11.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "pkg": "^5.8.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0"
}
